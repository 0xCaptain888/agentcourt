# AgentCourt Configuration
# Copy to .env and fill in your values

# Wallet private key (NEVER commit this!)
PRIVATE_KEY=0x...

# 0G Network RPCs
OG_TESTNET_RPC=https://evmrpc-testnet.0g.ai
OG_MAINNET_RPC=https://evmrpc.0g.ai

# TEE Signer addresses (from 0G Compute Provider)
TEE_SIGNER_ADDRESS=0x...
ARBITER_TEE_SIGNER=0x...

# Contract addresses (populated after deployment)
AGENTCOURT_TASK_REGISTRY=
AGENTCOURT_DISPUTE_RESOLVER=
AGENTCOURT_AGENT_REGISTRY=

# 0G Storage
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_KV_NODE_RPC=https://kv-testnet.0g.ai
OG_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
